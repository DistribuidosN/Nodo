{
  "architecture": "app-server-java-to-python-workers",
  "grpc_endpoints": {
    "workers": [
      {
        "node_id": "worker-1",
        "target": "127.0.0.1:50051",
        "services": [
          "imagenode.ImageNodeService",
          "worker.WorkerControlService",
          "worker.WorkerNode"
        ]
      },
      {
        "node_id": "worker-2",
        "target": "127.0.0.1:50061",
        "services": [
          "imagenode.ImageNodeService",
          "worker.WorkerControlService",
          "worker.WorkerNode"
        ]
      },
      {
        "node_id": "worker-3",
        "target": "127.0.0.1:50071",
        "services": [
          "imagenode.ImageNodeService",
          "worker.WorkerControlService",
          "worker.WorkerNode"
        ]
      }
    ],
    "app_server_orchestrator_endpoint": {
      "service": "worker.Orchestrator",
      "configured_by": [
        "APP_SERVER_GRPC_TARGET",
        "WORKER_COORDINATOR_TARGET"
      ],
      "example_target": "127.0.0.1:50051",
      "note": "Este endpoint no se despliega en este repo. Lo debe exponer el servidor principal Java para coordinar pulls, heartbeats y entrega de resultados."
    }
  },
  "grpc_methods": {
    "imagenode.ImageNodeService": [
      "ProcessToPath",
      "ProcessToData",
      "HealthCheck",
      "GetMetrics",
      "UploadLargeImage",
      "StreamBatchProcess",
      "GetProcessedFilePaths",
      "FindPathByName",
      "GetProcessedImages",
      "FindImageByName",
      "ProcessBatch"
    ],
    "worker.WorkerControlService": [
      "SubmitTask",
      "GetNodeStatus",
      "CancelTask",
      "DrainNode",
      "ShutdownNode"
    ],
    "worker.Orchestrator": [
      "PullTasks",
      "SubmitResult",
      "StealTasks",
      "UpdateTaskProgress",
      "SendHeartbeat",
      "GetQueueStatus",
      "WatchQueue"
    ],
    "worker.WorkerNode": [
      "GetMetrics",
      "YieldTasks"
    ]
  },
  "http_endpoints": {
    "workers": [
      {
        "node_id": "worker-1",
        "livez": "http://127.0.0.1:8081/livez",
        "readyz": "http://127.0.0.1:8081/readyz",
        "metrics": "http://127.0.0.1:9101"
      },
      {
        "node_id": "worker-2",
        "livez": "http://127.0.0.1:8082/livez",
        "readyz": "http://127.0.0.1:8082/readyz",
        "metrics": "http://127.0.0.1:9102"
      },
      {
        "node_id": "worker-3",
        "livez": "http://127.0.0.1:8083/livez",
        "readyz": "http://127.0.0.1:8083/readyz",
        "metrics": "http://127.0.0.1:9103"
      }
    ]
  },
  "worker_data_layout": {
    "input_dir": "/app/data/input",
    "output_dir": "/app/data/output",
    "state_dir": "/app/data/state"
  },
  "repo_files": {
    "business_proto": "proto/imagenode.proto",
    "control_proto": "proto/worker_node.proto",
    "orchestrator_proto": "proto/orchestrator.proto",
    "docker_compose": "docker-compose.yml",
    "env_example": ".env.example",
    "readme": "README.md",
    "demo_script": "scripts/demo/demo_end_to_end.py"
  }
}
