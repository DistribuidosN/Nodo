{
  "architecture": "app-server-java-to-python-workers",
  "grpc_endpoints": {
    "workers": [
      {
        "node_id": "worker-1",
        "target": "127.0.0.1:50051",
        "services": [
          "imagenode.ImageNodeService",
          "worker.WorkerControlService"
        ]
      },
      {
        "node_id": "worker-2",
        "target": "127.0.0.1:50061",
        "services": [
          "imagenode.ImageNodeService",
          "worker.WorkerControlService"
        ]
      },
      {
        "node_id": "worker-3",
        "target": "127.0.0.1:50071",
        "services": [
          "imagenode.ImageNodeService",
          "worker.WorkerControlService"
        ]
      }
    ],
    "optional_app_server_callback_endpoint": {
      "service": "worker.CoordinatorCallbackService",
      "configured_by": [
        "APP_SERVER_GRPC_TARGET",
        "WORKER_COORDINATOR_TARGET"
      ],
      "example_target": "127.0.0.1:50052",
      "note": "Este endpoint no se despliega en este repo. Lo debe exponer el servidor principal Java si quiere recibir callbacks."
    }
  },
  "grpc_methods": {
    "imagenode.ImageNodeService": [
      "ProcessToPath",
      "ProcessToData",
      "HealthCheck",
      "GetMetrics",
      "UploadLargeImage",
      "StreamBatchProcess",
      "GetProcessedFilePaths",
      "FindPathByName",
      "GetProcessedImages",
      "FindImageByName",
      "ProcessBatch"
    ],
    "worker.WorkerControlService": [
      "SubmitTask",
      "GetNodeStatus",
      "CancelTask",
      "DrainNode",
      "ShutdownNode"
    ],
    "worker.CoordinatorCallbackService": [
      "ReportProgress",
      "ReportResult",
      "Heartbeat"
    ]
  },
  "http_endpoints": {
    "workers": [
      {
        "node_id": "worker-1",
        "livez": "http://127.0.0.1:8081/livez",
        "readyz": "http://127.0.0.1:8081/readyz",
        "metrics": "http://127.0.0.1:9101"
      },
      {
        "node_id": "worker-2",
        "livez": "http://127.0.0.1:8082/livez",
        "readyz": "http://127.0.0.1:8082/readyz",
        "metrics": "http://127.0.0.1:9102"
      },
      {
        "node_id": "worker-3",
        "livez": "http://127.0.0.1:8083/livez",
        "readyz": "http://127.0.0.1:8083/readyz",
        "metrics": "http://127.0.0.1:9103"
      }
    ],
    "observability": {
      "prometheus": "http://127.0.0.1:9090",
      "grafana": "http://127.0.0.1:3000"
    },
    "storage": {
      "minio_api": "http://127.0.0.1:9000",
      "minio_console": "http://127.0.0.1:9001"
    }
  },
  "storage_uris": {
    "state_prefix": "s3://distributed-state/workers",
    "output_prefixes": [
      "s3://distributed-output/worker-1",
      "s3://distributed-output/worker-2",
      "s3://distributed-output/worker-3"
    ]
  },
  "repo_files": {
    "business_proto": "proto/imagenode.proto",
    "control_proto": "proto/worker_node.proto",
    "docker_compose": "docker-compose.yml",
    "env_example": ".env.example",
    "readme": "README.md",
    "demo_script": "scripts/demo_end_to_end.py",
    "real_image_script": "examples/send_real_image.py",
    "mock_app_server": "examples/mock_app_server.py"
  }
}
